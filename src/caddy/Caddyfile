{
	auto_https off
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

:{$PORT} {
	log {
		output discard
	}

	# IP Blocklist (generated from $BLOCKLIST, comma-separated IPs/CIDRs)
	import blocklist.caddy

	# Geo-blocking (generated from $GEO_ALLOWED_COUNTRIES, comma-separated country codes)
	import geoblocking.caddy

	# Rate limiting - general: 100 req / 10s per IP
	rate_limit {
		zone general {
			key {http.request.header.X-Forwarded-For}
			events 100
			window 10s
		}
	}

	# Rate limiting - API: 20 req / 10s per IP
	route /api/* {
		rate_limit {
			zone api {
				key {http.request.header.X-Forwarded-For}
				events 20
				window 10s
			}
		}
	}

	# Reverse proxy to Next.js
	reverse_proxy localhost:3000 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {client_ip}
	}
}
