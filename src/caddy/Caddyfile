{
	auto_https off
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

:{$PORT} {
	log {
		output stderr
	}

	# IP Blocklist (generated from $ACL_BLOCKED_IPS, comma-separated IPs/CIDRs)
	import blocklist.caddy

	# Geo-blocking (generated from $ACL_ALLOWED_COUNTRIES, comma-separated country codes)
	import geoblocking.caddy

	# Rate limiting - general
	rate_limit {
		zone general {
			key {client_ip}
			events {$RATE_LIMIT_GENERAL_EVENTS:100}
			window {$RATE_LIMIT_GENERAL_WINDOW:10s}
		}
	}

	# Rate limiting - API
	route /api/* {
		rate_limit {
			zone api {
				key {client_ip}
				events {$RATE_LIMIT_API_EVENTS:20}
				window {$RATE_LIMIT_API_WINDOW:10s}
			}
		}
	}

	handle_errors {
		@ratelimited expression `{err.status_code} == 429`
		respond @ratelimited "Rate limit exceeded" 429
	}

	# Reverse proxy to Next.js
	reverse_proxy localhost:3000 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {client_ip}
	}
}
