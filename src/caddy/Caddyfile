{
	auto_https off
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

:{$PORT} {
	log {
		output discard
	}

	# IP Blocklist from $BLOCKLIST env var (space-separated IPs/CIDRs)
	@blocked client_ip {$BLOCKLIST:}
	respond @blocked 403

	# Geo-blocking from $GEO_ALLOWED_COUNTRIES env var (space-separated country codes)
	@geoblocked not {
		maxmind_geolocation {
			db_path ./dumps/geoip-country.mmdb
			allow_countries {$GEO_ALLOWED_COUNTRIES:}
		}
	}
	respond @geoblocked 403

	# Rate limiting - general: 100 req / 10s per IP
	rate_limit {
		zone general {
			key {http.request.header.X-Forwarded-For}
			events 100
			window 10s
		}
	}

	# Rate limiting - API: 20 req / 10s per IP
	route /api/* {
		rate_limit {
			zone api {
				key {http.request.header.X-Forwarded-For}
				events 20
				window 10s
			}
		}
	}

	# Reverse proxy to Next.js
	reverse_proxy localhost:3000 {
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-For {client_ip}
	}
}
