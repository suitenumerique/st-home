#!/bin/bash

set -o errexit    # always exit on error
set -o pipefail   # don't ignore exit codes when piping output

echo "-----> Running post-frontend script"

make data-geoip-download

mv data/* .
mv src/caddy/* .

CADDY_VERSION="v2.11.2"
echo "-----> Downloading Caddy ${CADDY_VERSION} with plugins"
mkdir -p bin
curl -LSs -o bin/caddy "https://caddyserver.com/api/download?os=linux&arch=amd64&version=${CADDY_VERSION}&p=github.com/mholt/caddy-ratelimit&p=github.com/porech/caddy-maxmind-geolocation"
chmod +x bin/caddy

echo "3.13" > .python-version
