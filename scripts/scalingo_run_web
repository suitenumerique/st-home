#!/bin/bash

# Rate limiting (empty = disabled)
if [ -n "$PROXY_RATE_LIMIT_EVENTS" ]; then
  cat > ratelimit.caddy <<EOF
rate_limit {
	zone global {
		key {client_ip}
		events $PROXY_RATE_LIMIT_EVENTS
		window ${PROXY_RATE_LIMIT_WINDOW:-10s}
	}
}
EOF
else
  : > ratelimit.caddy
fi

# Worker dashboard — only exposed when both an IP allowlist and basic-auth
# credentials are configured (fail closed). The Python process binds to
# localhost; Caddy serves it at /$WORKER_DASHBOARD_URL behind the guards below.
if [ -n "$WORKER_DASHBOARD_BASICAUTH_HASH" ] && [ -n "$WORKER_DASHBOARD_ALLOWED_IPS" ]; then
  WORKER_DASHBOARD_HOST=127.0.0.1 WORKER_DASHBOARD_PORT="${WORKER_DASHBOARD_PORT:-8090}" \
    python dashboard.py &
  cat > dashboard.caddy <<'EOF'
handle /{$WORKER_DASHBOARD_URL:worker-dashboard}* {
	route {
		@dash_denied not client_ip {$WORKER_DASHBOARD_ALLOWED_IPS}
		respond @dash_denied "Access denied" 403
		basic_auth {
			{$WORKER_DASHBOARD_BASICAUTH_USER} {$WORKER_DASHBOARD_BASICAUTH_HASH}
		}
		reverse_proxy 127.0.0.1:{$WORKER_DASHBOARD_PORT:8090}
	}
}
EOF
else
  : > dashboard.caddy
fi

# Start the NextJS server
npm run start &

# Start the Caddy server
bin/caddy run --config Caddyfile &

# if the current shell is killed, also terminate all its children
trap "pkill -SIGTERM -P $$" SIGTERM

# wait for a single child to finish,
wait -n
# then kill all the other tasks
pkill -P $$ 2>/dev/null || true
wait
