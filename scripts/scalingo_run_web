#!/bin/bash

# Scalingo does not support empty env vars, so we use "-" as a placeholder meaning "disabled".
# During an incident, replace "-" with actual values (e.g. "1.2.3.4" or "FR").
DISABLED="-"

# Generate blocklist snippet from $ACL_BLOCKED_IPS (comma-separated IPs/CIDRs, e.g. "1.2.3.4,5.6.7.0/24")
if [ -n "$ACL_BLOCKED_IPS" ] && [ "$ACL_BLOCKED_IPS" != "$DISABLED" ]; then
  BLOCKED_IPS_SPACED=$(echo "$ACL_BLOCKED_IPS" | tr ',' ' ')
  cat > blocklist.caddy <<EOF
@blocked client_ip $BLOCKED_IPS_SPACED
respond @blocked "Access denied" 403
EOF
else
  : > blocklist.caddy
fi

# Generate geo-blocking snippet from $ACL_ALLOWED_COUNTRIES (comma-separated country codes, e.g. "FR,DE")
if [ -n "$ACL_ALLOWED_COUNTRIES" ] && [ "$ACL_ALLOWED_COUNTRIES" != "$DISABLED" ]; then
  ALLOWED_COUNTRIES_SPACED=$(echo "$ACL_ALLOWED_COUNTRIES" | tr ',' ' ')
  cat > geoblocking.caddy <<EOF
@geoblocked not {
	maxmind_geolocation {
		db_path ./dumps/geoip-country.mmdb
		allow_countries $ALLOWED_COUNTRIES_SPACED
	}
}
respond @geoblocked "Access denied" 403
EOF
else
  : > geoblocking.caddy
fi

# Start the NextJS server
npm run start &

# Start the Caddy server
bin/caddy run --config Caddyfile &

# if the current shell is killed, also terminate all its children
trap "pkill SIGTERM -P $$" SIGTERM

# wait for a single child to finish,
wait -n
# then kill all the other tasks
pkill -P $$
