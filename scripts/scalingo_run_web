#!/bin/bash

# Generate blocklist snippet from $BLOCKLIST (comma-separated IPs/CIDRs, e.g. "1.2.3.4,5.6.7.0/24")
BLOCKLIST_CLEANED=$(echo "$BLOCKLIST" | tr -d ' ')
if [ -n "$BLOCKLIST_CLEANED" ]; then
  BLOCKLIST_SPACED=$(echo "$BLOCKLIST_CLEANED" | tr ',' ' ')
  cat > blocklist.caddy <<EOF
@blocked client_ip $BLOCKLIST_SPACED
respond @blocked "Access denied" 403
EOF
else
  : > blocklist.caddy
fi

# Generate geo-blocking snippet from $GEO_ALLOWED_COUNTRIES (comma-separated country codes, e.g. "FR,DE")
GEO_CLEANED=$(echo "$GEO_ALLOWED_COUNTRIES" | tr -d ' ')
if [ -n "$GEO_CLEANED" ]; then
  GEO_SPACED=$(echo "$GEO_CLEANED" | tr ',' ' ')
  cat > geoblocking.caddy <<EOF
@geoblocked not {
	maxmind_geolocation {
		db_path ./dumps/geoip-country.mmdb
		allow_countries $GEO_SPACED
	}
}
respond @geoblocked "Access denied" 403
EOF
else
  : > geoblocking.caddy
fi

# Start the NextJS server
npm run start &

# Start the Caddy server
bin/caddy run --config Caddyfile &

# if the current shell is killed, also terminate all its children
trap "pkill SIGTERM -P $$" SIGTERM

# wait for a single child to finish,
wait -n
# then kill all the other tasks
pkill -P $$
